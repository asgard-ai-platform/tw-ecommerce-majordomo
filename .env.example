# =============================================================================
# tw-ecommerce-majordomo — Consolidated MCP credentials
# =============================================================================
# Copy to .env (or export in your shell / direnv) and fill in only the values
# for the MCP servers you actually want to use. Each MCP server only needs the
# vars in its own section.
#
# All 12 MCPs are declared in the plugin manifests, but a missing env var only
# disables that single server — it does not break the rest.

# -----------------------------------------------------------------------------
# ECPay 綠界 — payment + (separately) logistics
#   MCPs: ecpay, ecpay-logistics
# -----------------------------------------------------------------------------
ECPAY_ENV=stage                  # stage | prod
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
ECPAY_PLATFORM_ID=               # only for ecpay (special-merchant flow)

# -----------------------------------------------------------------------------
# NewebPay 藍新 — payment (NDNF online + NDNP recurring)
#   MCP: newebpay
# -----------------------------------------------------------------------------
NEWEBPAY_ENV=test                # test | production
NEWEBPAY_NDNF_MERCHANT_ID=
NEWEBPAY_NDNF_HASH_KEY=
NEWEBPAY_NDNF_HASH_IV=
NEWEBPAY_NDNP_MERCHANT_ID=
NEWEBPAY_NDNP_HASH_KEY=
NEWEBPAY_NDNP_HASH_IV=

# -----------------------------------------------------------------------------
# Kerry TJ 嘉里大榮 — logistics tracing + EDI
#   MCP: kerry-tj
# -----------------------------------------------------------------------------
KERRY_TJ_USERNAME=
KERRY_TJ_PASSWORD=

# -----------------------------------------------------------------------------
# HCT 新竹貨運 — EDI logistics
#   MCP: hct-logistics
# -----------------------------------------------------------------------------
HCT_COMPANY=
HCT_PASSWORD=

# -----------------------------------------------------------------------------
# SF Express 順豐 — OAuth2 + std/service
#   MCP: sf-express
# -----------------------------------------------------------------------------
SF_ENV=sandbox                   # sandbox | prod
SF_PARTNER_ID=
SF_SECRET=

# -----------------------------------------------------------------------------
# Shopline — DTC platform
#   MCP: shopline
# -----------------------------------------------------------------------------
SHOPLINE_API_TOKEN=

# -----------------------------------------------------------------------------
# 91APP — DTC platform (multi-auth: Admin / IMS / Payments / Member)
#   MCP: 91app    (PRIVATE repo — requires asgard-ai-platform org access)
# -----------------------------------------------------------------------------
APP_91APP_API_KEY=
APP_91APP_BASE_URL=https://api.91app.com
APP_91APP_SHOP_ID=0
APP_91APP_N1_API_KEY=
APP_91APP_IMS_BASE_URL=https://ims-api.91app.com
APP_91APP_HMAC_SECRET=
APP_91APP_PAYMENTS_BASE_URL=https://payments-api.91app.com
APP_91APP_NY_API_TOKEN=
APP_91APP_MEMBER_BASE_URL=https://member-api.91app.com

# -----------------------------------------------------------------------------
# Cyberbiz — DTC platform (HMAC-SHA256)
#   MCP: cyberbiz   (PRIVATE repo — requires asgard-ai-platform org access)
# -----------------------------------------------------------------------------
CYBERBIZ_USERNAME=
CYBERBIZ_SECRET=

# -----------------------------------------------------------------------------
# buy123 vendor portal
#   MCP: buy123-vendor
# -----------------------------------------------------------------------------
BUY123_VENDOR_ID=
BUY123_VENDOR_EMAIL=
BUY123_VENDOR_PASSWORD=

# -----------------------------------------------------------------------------
# ezPay 簡單付 — e-invoice
#   MCP: ezpay-einvoice
# -----------------------------------------------------------------------------
EZPAY_MERCHANT_ID=
EZPAY_HASH_KEY=
EZPAY_HASH_IV=
EZPAY_IS_PRODUCTION=false        # true → production endpoint

# -----------------------------------------------------------------------------
# Universal EC 汎宇電商 — e-invoice
#   MCP: universalec-einvoice
# -----------------------------------------------------------------------------
EINVOICE_BASE_URL=https://epostw.einvoice.com.tw/GetInvoice.ashx
EINVOICE_SELLER_ID=
EINVOICE_POS_ID=
EINVOICE_POS_SN=
